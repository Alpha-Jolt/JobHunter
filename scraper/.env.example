# Environment — copy to .env and fill in values

# --- Scraper ---
HEADLESS=true
BROWSER_POOL_SIZE=3
SCRAPER_TIMEOUT_MS=30000
DEBUG_SCREENSHOTS=false
DEV_MODE=true

# --- Rate Limiting ---
INDEED_RATE_LIMIT=1.0
NAUKRI_RATE_LIMIT=0.5

# --- Proxy ---
PROXY_LIST=
PROXY_STRATEGY=round_robin
PROXY_FALLBACK_TO_DIRECT=true

# --- Retry ---
MAX_RETRIES=3
RETRY_BASE_DELAY=2.0
RETRY_MAX_DELAY=60.0

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=logs

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Output ---
OUTPUT_DIR=output
OUTPUT_FORMATS=json,csv

# --- Pipeline ---
PAGES_PER_SEARCH=1
