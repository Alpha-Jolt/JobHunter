# AI Engine Environment Configuration
# Copy this file to .env and fill in your API keys

# Application
APP_NAME=JobHunter-AIEngine
ENVIRONMENT=development

# LLM Provider Keys (fill in at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROK_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# LLM Settings
LLM_PRIMARY_PROVIDER=anthropic
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=60

# Variant Budget
MAX_VARIANTS_TOTAL=50
MAX_VARIANTS_PER_SESSION=10

# Paths
PATH_SCRAPER_OUTPUT_DIR=output/final
PATH_AI_OUTPUT_DIR=ai_output
PATH_PROMPTS_DIR=ai_engine/features/llm/prompting/prompts
PATH_VARIANT_REGISTRY_PATH=ai_output/variant_registry.json

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Approval Token Secret (generate a strong random string)
APPROVAL_TOKEN_SECRET=change-me-to-a-strong-random-secret
